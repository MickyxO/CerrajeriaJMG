PORT=3000
NODE_ENV=development

# Required: Neon/PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Timezone used by reports/sales dates
DB_TIMEZONE=America/Mexico_City
APP_TIMEZONE=America/Mexico_City

# Optional Neon transport
NEON_USE_WEBSOCKET=false

# Frontend origin(s), comma separated
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# Local bootstrap and uploads
ALLOW_PUBLIC_USER_CREATE=false
SERVE_LOCAL_UPLOADS=true

# Swagger exposure in local/dev
ENABLE_SWAGGER=true
SWAGGER_USER=
SWAGGER_PASS=

# Optional Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=